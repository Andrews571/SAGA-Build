+		rq = task_rq(task);
+		rq_lock_irqsave(rq, &rf);
+		reweight_task(task, effective_prio(task));
+		rq_unlock_irqrestore(rq, &rf);
+	}
+	write_unlock_irq(&tasklist_lock);
+}
