# Mountify / OverlayFS
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y

# Kallsyms
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# Performance
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_FRAME_WARN=0

# ZRAM
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_MEMORY_TRACKING=y

# I/O Scheduler
CONFIG_MQ_IOSCHED_DEADLINE=y

# F2FS
CONFIG_F2FS_FS_XATTR=y
CONFIG_F2FS_FS_POSIX_ACL=y

# TCP BBR
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_BIC=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_TCP_CONG_HTCP=y
# NOTE: CONFIG_DEFAULT_TCP_CONG is intentionally NOT set here.
# It has no Kconfig prompt (pure "default X if DEFAULT_Y" string), so any
# literal value written in a defconfig/fragment is discarded and recomputed
# from the DEFAULT_BBR/DEFAULT_CUBIC/DEFAULT_BBR3/etc. choice state during
# `make olddefconfig`. To change the actual default congestion control,
# set the corresponding CONFIG_DEFAULT_<ALGO>=y choice member instead
# (see kernel/addons/bbrv3/bbrv3.sh for the working pattern).
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y

# IP Set
CONFIG_IP_SET=y
CONFIG_IP_SET_MAX=65534
CONFIG_IP_SET_BITMAP_IP=y
CONFIG_IP_SET_BITMAP_IPMAC=y
CONFIG_IP_SET_BITMAP_PORT=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_IPMARK=y
CONFIG_IP_SET_HASH_IPPORT=y
CONFIG_IP_SET_HASH_IPPORTIP=y
CONFIG_IP_SET_HASH_IPPORTNET=y
CONFIG_IP_SET_HASH_IPMAC=y
CONFIG_IP_SET_HASH_MAC=y
CONFIG_IP_SET_HASH_NETPORTNET=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_IP_SET_HASH_NETNET=y
CONFIG_IP_SET_HASH_NETPORT=y
CONFIG_IP_SET_HASH_NETIFACE=y
CONFIG_IP_SET_LIST_SET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y

# IPv6 NAT
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_TARGET_HL=y
CONFIG_IP6_NF_MATCH_HL=y

# Networking extras
CONFIG_IP_NF_TARGET_TTL=y

# Disable debug overhead
CONFIG_UBSAN=n
CONFIG_PAGE_OWNER=n
CONFIG_RCU_TRACE=n
